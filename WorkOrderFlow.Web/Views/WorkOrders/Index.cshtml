@model IEnumerable<WorkOrderFlow.Web.Models.WorkOrder>

@{
    ViewData["Title"] = "Work Orders";
}

<h1>Work Orders</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Work Order</a>
</p>

<table class="table table-sm table-striped align-middle">
    <thead>
        <tr>
            <th>Customer</th>
            <th>Quote</th>
            <th>Title</th>
            <th>Status</th>
            <th>Priority</th>
            <th>Due Date</th>
            <th>Created</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>
                @(item.Customer?.FullName ?? $"Customer #{item.CustomerId}")
            </td>
            <td>
                @(item.Quote?.Title ?? "-")
            </td>
            <td>
                @item.Title
            </td>
            <td>
                @{
                    var statusClass = item.Status switch
                    {
                        WorkOrderFlow.Web.Models.WorkOrderStatus.New => "badge bg-secondary",
                        WorkOrderFlow.Web.Models.WorkOrderStatus.Approved => "badge bg-info text-dark",
                        WorkOrderFlow.Web.Models.WorkOrderStatus.InProgress => "badge bg-primary",
                        WorkOrderFlow.Web.Models.WorkOrderStatus.WaitingParts => "badge bg-warning text-dark",
                        WorkOrderFlow.Web.Models.WorkOrderStatus.Completed => "badge bg-success",
                        WorkOrderFlow.Web.Models.WorkOrderStatus.Delivered => "badge bg-dark",
                        WorkOrderFlow.Web.Models.WorkOrderStatus.Cancelled => "badge bg-danger",
                        _ => "badge bg-secondary"
                    };
                }
                <span class="@statusClass">@item.Status</span>
            </td>
            <td>
                @{
                    var priorityClass = item.Priority switch
                    {
                        WorkOrderFlow.Web.Models.WorkOrderPriority.Low => "badge bg-secondary",
                        WorkOrderFlow.Web.Models.WorkOrderPriority.Medium => "badge bg-info text-dark",
                        WorkOrderFlow.Web.Models.WorkOrderPriority.High => "badge bg-warning text-dark",
                        WorkOrderFlow.Web.Models.WorkOrderPriority.Urgent => "badge bg-danger",
                        _ => "badge bg-secondary"
                    };
                }
                <span class="@priorityClass">@item.Priority</span>
            </td>
            <td>
                @item.DueDate?.ToString("dd.MM.yyyy")
            </td>
            <td>
                @item.CreatedAt.ToString("dd.MM.yyyy")
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>