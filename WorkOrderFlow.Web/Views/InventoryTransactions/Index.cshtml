@model IEnumerable<WorkOrderFlow.Web.Models.InventoryTransaction>
@using WorkOrderFlow.Web.Models

@{
    ViewData["Title"] = "Stock Movements";

    var currentSearch = ViewData["CurrentSearch"] as string;
    var currentType = ViewData["CurrentType"] as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">Stock Movements</h1>
        <div class="text-muted">Track inventory usage, reversals and quantity changes.</div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-7">
                <label class="form-label">Search</label>
                <input type="text"
                       name="search"
                       value="@currentSearch"
                       class="form-control"
                       placeholder="Search item, SKU, work order or notes..." />
            </div>

            <div class="col-md-3">
                <label class="form-label">Type</label>
                <select name="type" class="form-select">
                    <option value="">All types</option>
                    @foreach (var item in Html.GetEnumSelectList<InventoryTransactionType>())
                    {
                        if (item.Value == currentType)
                        {
                            <option value="@item.Value" selected>@item.Text</option>
                        }
                        else
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-dark">Filter</button>
            </div>

            <div class="col-md-12">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear filters</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No stock movements found yet.
    </div>
}
else
{
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>Date</th>
                <th>Item</th>
                <th>SKU</th>
                <th>Work Order</th>
                <th>Type</th>
                <th>Change</th>
                <th>Quantity After</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model)
{
            var changeClass = item.QuantityChange < 0 ? "badge bg-danger" : "badge bg-success";
            var changeText = item.QuantityChange > 0 ? $"+{item.QuantityChange}" : item.QuantityChange.ToString();

            <tr>
                <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                <td>@(item.InventoryItem?.Name ?? $"Item #{item.InventoryItemId}")</td>
                <td>@item.InventoryItem?.Sku</td>
                <td>@(item.WorkOrder?.Title ?? "-")</td>
                <td>
                    <span class="badge bg-secondary">@item.Type</span>
                </td>
                <td>
                    <span class="@changeClass">@changeText</span>
                </td>
                <td>
                    <strong>@item.QuantityAfter</strong>
                </td>
                <td>@item.Notes</td>
            </tr>
}
        </tbody>
    </table>
}
