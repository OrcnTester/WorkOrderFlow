@model IEnumerable<WorkOrderFlow.Web.Models.WorkOrderMaterial>

@{
    ViewData["Title"] = "Materials Used";
}

<h1>Materials Used</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add Material Usage</a>
</p>

<table class="table table-sm table-striped align-middle">
    <thead>
        <tr>
            <th>Work Order</th>
            <th>Inventory Item</th>
            <th>Quantity</th>
            <th>Unit Price</th>
            <th>Total</th>
            <th>Used At</th>
            <th>Notes</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@(item.WorkOrder?.Title ?? $"Work Order #{item.WorkOrderId}")</td>
            <td>@(item.InventoryItem?.Name ?? $"Inventory Item #{item.InventoryItemId}")</td>
            <td>@item.QuantityUsed</td>
            <td>@item.UnitPrice.ToString("N2") ₺</td>
            <td><strong>@item.LineTotal.ToString("N2") ₺</strong></td>
            <td>@item.UsedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
            <td>@item.Notes</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>